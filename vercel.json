{
  "buildCommand": "bun run build",
  "framework": null,
  "outputDirectory": "dist/client",
  "functions": {
    "api/[...path].js": {
      "runtime": "nodejs20.x",
      "includeFiles": "dist/server/**",
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/(.*)", "destination": "/api/[...path]" }
  ]
}
